# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api

# Public URL used by middleware/browser OAuth hand-off
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anon key used by middleware/browser/server auth helpers
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional server-only aliases (kept for compatibility)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Enable Kakao social CTA only after the provider is configured in Supabase
NEXT_PUBLIC_ENABLE_KAKAO_AUTH=0
